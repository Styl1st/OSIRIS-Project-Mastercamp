#!/var/ossec/framework/python/bin/python3
# =============================================================================
# custom-discord — Integration Wazuh -> webhook Discord (Phase 2, alerting)
# A deployer sur le manager : /var/ossec/integrations/custom-discord
#   chmod 750 ; chown root:wazuh
# Config ossec.conf :
#   <integration>
#     <name>custom-discord</name>
#     <hook_url>https://discord.com/api/webhooks/XXXX/YYYY</hook_url>   <!-- SECRET, hors git -->
#     <level>12</level>
#     <alert_format>json</alert_format>
#   </integration>
# Args passes par integratord : $1 = fichier alerte JSON, $2 = api_key, $3 = hook_url
# =============================================================================
import sys, json, os, ssl
from urllib import request

with open(sys.argv[1]) as f:
    alert = json.load(f)
hook = sys.argv[3]

rule  = alert.get('rule', {})
agent = alert.get('agent', {})
content = (
    ":rotating_light: **Alerte Wazuh** - niveau %s\n"
    "**Regle %s** : %s\n"
    "**Agent** : %s\n"
    "```%s```"
) % (rule.get('level', '?'), rule.get('id', '?'),
     rule.get('description', '?'), agent.get('name', '?'),
     (alert.get('full_log') or '')[:400])

# Le Python embarque de Wazuh n'a pas de bundle CA -> on en charge un si dispo,
# sinon on desactive la verif (repli de lab ; en prod, fournir un vrai bundle CA).
ctx = ssl.create_default_context()
ca = next((p for p in ("/etc/ssl/certs/ca-certificates.crt",
                       "/etc/pki/tls/certs/ca-bundle.crt",
                       "/etc/ssl/cert.pem") if os.path.exists(p)), None)
if ca:
    ctx.load_verify_locations(ca)
else:
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE

# Discord bloque le User-Agent par defaut de Python (403) -> on en met un custom.
body = json.dumps({"content": content}).encode()
req = request.Request(hook, data=body, headers={
    "Content-Type": "application/json",
    "User-Agent": "Wazuh-Discord-Integration"
})
request.urlopen(req, timeout=10, context=ctx)
